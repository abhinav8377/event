{
  "name": "event-discovery-management-system",
  "version": "1.0.0",
  "description": "Event Discovery & Management Platform (MERN Monorepo)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "server": "tsx watch server.ts",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "tsx seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.5",
    "@clerk/clerk-react": "^5.61.9",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
